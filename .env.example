# --- Database ---
DATABASE_URL="postgresql://secondhand:secondhand@localhost:5432/secondhand_market?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- JWT ---
# Fine to boot local dev with as-is (min 32 chars, enforced at startup), but
# the API refuses to boot in production with these exact placeholder values
# still in place — generate real secrets (e.g. `openssl rand -base64 48`)
# before deploying.
JWT_ACCESS_SECRET="change-me-access-secret-please-generate-a-real-one"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret-please-generate-a-real-one"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Report / moderation ---
REPORT_BLOCK_THRESHOLD=5

# --- Rate limiting (global default; auth endpoints override with a stricter limit) ---
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# --- Object storage (S3-compatible, presigned URLs) ---
# Points at the local MinIO container from docker-compose.yml by default;
# swap for real AWS S3 in production by clearing S3_ENDPOINT and using AWS
# credentials + region.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="secondhand-market-dev"
S3_ACCESS_KEY_ID="secondhand"
S3_SECRET_ACCESS_KEY="secondhand123"
S3_PRESIGNED_URL_EXPIRES_IN=300

# --- API ---
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"

# --- Web ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="http://localhost:4000"
